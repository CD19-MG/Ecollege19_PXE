<?xml version="1.0" encoding="utf-8"?>
<!--
  ImageUnattend.xml — phase OS (specialize + oobeSystem) : locale, jonction ecollege19.lan,
  compte admin local, OOBE silencieux. À rattacher à l'Install Image dans WDS
  (Propriétés de l'image > "Autoriser l'installation en mode sans assistance" > ce fichier),
  ou à placer dans l'image. ⚠️ Mot de passe de jonction + admin local = SECRETS : garder les
  vraies valeurs dans une copie locale gitignorée (*.local.xml), jamais dans le dépôt.
-->
<unattend xmlns="urn:schemas-microsoft-com:unattend">
  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup" processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <!-- Nom auto par n° de série (<=15 car.) ; ou retirer pour saisir/laisser aléatoire -->
      <ComputerName>*</ComputerName>
      <TimeZone>Romance Standard Time</TimeZone>
    </component>
    <component name="Microsoft-Windows-UnattendedJoin" processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <Identification>
        <JoinDomain>ecollege19.lan</JoinDomain>
        <!-- Cible de l'objet ordinateur. Si ABSENT/commente -> conteneur par defaut
             "CN=Computers" (c'est un CONTAINER : prefixe CN, PAS OU). Pour une vraie OU
             creee dans l'AD, utiliser OU=... ; ex : OU=Postes,OU=MARBOT,DC=ecollege19,DC=lan.
             Piege : "OU=Computers" n'existe PAS -> jonction refusee. Le defaut est CN=Computers. -->
        <!-- <MachineObjectOU>CN=Computers,DC=ecollege19,DC=lan</MachineObjectOU> -->
        <Credentials>
          <Domain>ecollege19.lan</Domain>
          <Username>&lt;COMPTE_DE_JONCTION&gt;</Username>
          <Password>&lt;REMPLIR_HORS_DEPOT&gt;</Password>
        </Credentials>
      </Identification>
    </component>
    <component name="Microsoft-Windows-Deployment" processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <RunSynchronous>
        <!-- Active le compte Administrateur LOCAL integre (SID -500) : robuste a la langue
             (en FR il s'appelle "Administrateur", pas "Administrator"). -->
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Path>powershell -NoProfile -Command "Get-LocalUser | Where-Object { $_.SID.Value -like '*-500' } | Enable-LocalUser"</Path>
          <Description>Activer l'administrateur local integre</Description>
        </RunSynchronousCommand>
        <!-- Empeche le chiffrement automatique de l'appareil (Windows 11 "device encryption") : sinon
             BitLocker s'active seul et BLOQUE le sysprep du master (et chiffre les clients en silence).
             A poser en specialize, AVANT l'OOBE. BitLocker reste activable ensuite par GPO si voulu. -->
        <RunSynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Path>reg add HKLM\SYSTEM\CurrentControlSet\Control\BitLocker /v PreventDeviceEncryption /t REG_DWORD /d 1 /f</Path>
          <Description>Empecher le chiffrement automatique BitLocker (sysprep master)</Description>
        </RunSynchronousCommand>
      </RunSynchronous>
    </component>
  </settings>
  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-International-Core" processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <InputLocale>fr-FR</InputLocale>
      <SystemLocale>fr-FR</SystemLocale>
      <UILanguage>fr-FR</UILanguage>
      <UserLocale>fr-FR</UserLocale>
    </component>
    <component name="Microsoft-Windows-Shell-Setup" processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideOEMRegistrationScreen>true</HideOEMRegistrationScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <ProtectYourPC>3</ProtectYourPC>
        <!-- Saute les pages OOBE machine/utilisateur ("Qui utilisera cet appareil ?").
             Deconseille par MS mais fiable et adapte a une image JOINTE AU DOMAINE (les comptes
             viennent de l'AD, pas de compte local a creer). Sans ca, l'OOBE s'arrete sur la
             creation de compte meme apres jonction reussie. -->
        <SkipMachineOOBE>true</SkipMachineOOBE>
        <SkipUserOOBE>true</SkipUserOOBE>
      </OOBE>
      <UserAccounts>
        <!-- Definit le mot de passe du compte Administrateur LOCAL integre (active en specialize
             ci-dessus). Mettre le vrai mot de passe dans la copie locale, jamais dans le depot. -->
        <AdministratorPassword>
          <Value>&lt;REMPLIR_HORS_DEPOT&gt;</Value>
          <PlainText>true</PlainText>
        </AdministratorPassword>
      </UserAccounts>
    </component>
  </settings>
</unattend>
